# ═══════════════════════════════════════════════════════════
# Coolify — انسخ هذه المتغيرات إلى Environment في Coolify
# ═══════════════════════════════════════════════════════════
#
# خطوات سريعة:
# 1) Coolify → New Resource → PostgreSQL → أنشئ قاعدة → انسخ Internal URL
# 2) Coolify → New Resource → Redis → أنشئ → انسخ Internal URL
# 3) Coolify → New Resource → Docker Compose → اربط ريبو life_manger
# 4) الصق المتغيرات بالأسفل → Deploy
# 5) بعد النشر: Terminal على web → python manage.py createsuperuser
#

DJANGO_SETTINGS_MODULE=config.settings.production
DEBUG=False

# مفتاح سري عشوائي طويل (غيّره)
SECRET_KEY=change-me-to-a-long-random-secret-key

# نطاقك بدون https://
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# نفس النطاق مع https (مهم لتسجيل الدخول)
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# من مورد PostgreSQL في Coolify (Internal Connection URL)
# مثال:
# DATABASE_URL=postgres://postgres:PASSWORD@xxxxxxxx:5432/postgres
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE

# من مورد Redis في Coolify
# مثال:
# CELERY_BROKER_URL=redis://xxxxxxxx:6379/0
CELERY_BROKER_URL=redis://HOST:6379/0

# إذا طلب Coolify SSL لقاعدة البيانات ضع True
DB_SSL=False

# ── للتطوير المحلي فقط (لا تستخدمه على Coolify) ──
# DJANGO_SETTINGS_MODULE=config.settings.development
# DEBUG=True
# ALLOWED_HOSTS=localhost,127.0.0.1
# DATABASE_URL=sqlite:///db.sqlite3
# CELERY_BROKER_URL=redis://localhost:6379/0
