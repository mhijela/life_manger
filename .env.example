# ═══════════════════════════════════════════════════════════
# Coolify — انسخ هذه المتغيرات إلى Environment في Coolify
# ═══════════════════════════════════════════════════════════
#
# خطوات:
# 1) Coolify → PostgreSQL → انسخ Internal URL
# 2) Docker Compose → اربط الريبو → الصق المتغيرات → Deploy
# 3) افتح الدومين وأكمل شاشة إعداد المدير
# (لا تحتاج Redis للمشاريع الصغيرة)
#

DJANGO_SETTINGS_MODULE=config.settings.production
DEBUG=False
SECRET_KEY=change-me-to-a-long-random-secret-key

ALLOWED_HOSTS=postdelivery.pw,www.postdelivery.pw
CSRF_TRUSTED_ORIGINS=https://postdelivery.pw,https://www.postdelivery.pw

DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE
DB_SSL=False
USE_CELERY=False

# ── للتطوير المحلي — ملف .env ──
# DJANGO_SETTINGS_MODULE=config.settings.development
# DEBUG=True
# ALLOWED_HOSTS=localhost,127.0.0.1
# DATABASE_URL=sqlite:///db.sqlite3
